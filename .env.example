# Base de datos (Postgres)
DATABASE_URL="postgresql://usuario:password@localhost:5432/verduleria"

# Login del panel de administración (elegí vos usuario y contraseña)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambiar-esta-clave"

# Frase secreta para firmar los tokens de sesión del admin (texto largo y random)
JWT_SECRET="cambiar-por-un-texto-largo-y-random"

# Nombre del negocio (aparece en mensajes de WhatsApp y en la web)
STORE_NAME="Verdulería Fresca"

# Datos para que el cliente transfiera y vos confirmes el pago a mano
TRANSFER_ALIAS="mi.verduleria.alias"
TRANSFER_CBU="0000000000000000000000"
WHATSAPP_NUMBER="5490000000000"
